# TribeOS environment configuration (example)
# Copy this file to `.env` and fill in real values. Never commit `.env`.
#
# TribeOS uses a single Supabase project as the primary development database.
# There is no local PostgreSQL. Schema changes go through Alembic only —
# never edit the schema via the Supabase dashboard.

# --- Runtime ---
APP_ENV=development
# Comma-separated browser origins for CORS (Next.js local ports).
# CORS_ORIGINS=http://localhost:3000,http://localhost:3002

# --- Database (Supabase PostgreSQL) ---
# Async SQLAlchemy connection string for the Supabase Postgres instance.
# Example: postgresql+asyncpg://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
DATABASE_URL=

# --- Supabase ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
